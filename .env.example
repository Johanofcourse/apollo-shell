# Duke Energy's live outage-map API requires a Basic auth token, found
# via browser devtools (not officially documented). Format: "Basic <base64>"
DUKE_ENERGY_API_AUTH=Basic REPLACE_ME

# The endpoints below are each utility's own live outage-map backend,
# found via browser devtools - not officially documented public APIs.
# Kept out of the committed code on purpose (this repo is public) since
# the code itself is more valuable than any one utility's specific
# endpoint - re-finding one is a matter of repeating the same devtools
# process, not copying a secret.
DUKE_API_BASE=REPLACE_ME
DUKE_API_ORIGIN=REPLACE_ME
TECO_API_URL=REPLACE_ME
TECO_API_ORIGIN=REPLACE_ME
FPL_API_URL=REPLACE_ME
FPL_API_ORIGIN=REPLACE_ME

# JEA's outage map runs on Kubra's "Storm Center" product - these two ids
# were found by reading the outage-map page's own JS bundle rather than
# live devtools traffic. kubra.io itself is a shared vendor domain (not
# JEA-specific), hardcoded in fetch_jea_outages.py - only these two ids
# are JEA-specific and worth keeping out of the committed code.
JEA_STORMCENTER_INSTANCE_ID=REPLACE_ME
JEA_STORMCENTER_VIEW_ID=REPLACE_ME

# FPL runs a second, separate live outage feed for the Florida Panhandle
# (Gulf Power's former territory - merged into FPL corporately in 2021,
# but apparently never consolidated into the main map/feed). Same JSON
# shape as the main FPL_API_URL feed, found behind real Incapsula bot
# protection - needed a real browser session to find, not just curl.
FPL_NORTHWEST_API_URL=REPLACE_ME
FPL_NORTHWEST_API_REFERER=REPLACE_ME

# City of Tallahassee's outage map runs on a plain Esri ArcGIS REST
# service (esriemcs.com) - unlike FPL/TECO, there's no bot protection in
# front of it at all, just a normal CORS-enabled query endpoint. Found
# via Safari Web Inspector, not officially documented.
TALLAHASSEE_API_URL=REPLACE_ME

# Talquin Electric Cooperative's outage map runs on a third vendor
# platform (Siena Technologies, cache.sienatech.com) - no bot protection,
# no special header needed, just a required trackingCode query param
# (confirmed 2026-07-13 by testing which parts of the captured request
# actually mattered - the Client header and version/session params
# turned out not to be required, trackingCode alone is).
TALQUIN_API_URL=REPLACE_ME

# Florida Public Utilities Corporation's outage map runs on a fourth
# vendor platform (DataVoice's "Apprise" system, outageentry.com) - a
# POST endpoint, the real form fields are hardcoded in
# fetch_fpuc_outages.py itself (reproduced from a captured real
# request) since none of them are secrets, just this base URL is
# environment-specific enough to keep out of the committed code.
FPUC_API_URL=REPLACE_ME

# Peace River Electric Cooperative (PRECO) runs on the same Siena
# Technologies platform as Talquin (cache.sienatech.com) - same
# data/{CLIENT}/OUTAGE endpoint shape, just PRECO's own client code and
# trackingCode (confirmed 2026-07-13 by testing the same URL pattern
# Talquin already uses).
PRECO_API_URL=REPLACE_ME

# Florida Keys Electric Cooperative (FKEC) runs on a fifth distinct
# vendor platform (NISC's "cloud.coop" outage-map product, plain static
# JSON files hosted on S3/CloudFront - no trackingCode, no auth, wide-
# open CORS). summary.json is the live per-ZIP outage-count file;
# region.zipCode.json (same folder) is map polygon geometry, not outage
# data - a dead end, same class as PRECO's grid-geometry endpoint.
FKEC_API_URL=REPLACE_ME

# Tri-County Electric Cooperative (TCEC) runs on a sixth distinct
# vendor platform (a custom Microsoft IIS-hosted build, no trackingCode
# or auth). outageSummary.json is a real, live, but system-wide-only
# total (no per-county breakdown) - real per-region detail lives in the
# same folder's outagePolygons.json, confirmed to exist but seen empty
# every time so far (zero active outages) - its real field shape is
# still unknown, same "wait for a real event" situation FPUC's markers
# array was in before one finally populated. Counties.zip (a real Esri
# shapefile) turned out to be the map's background county-line
# reference layer, not real service-territory data - it lists 10
# counties including two in Georgia, a dead end for real coverage.
TCEC_API_URL=REPLACE_ME

# Escambia River Electric Cooperative (EREC) runs on the exact same
# vendor platform as TCEC (identical outageSummary.json/
# outagePolygons.json shape, same Microsoft IIS server) - just hosted
# directly off a raw IP:port over plain HTTP rather than a proper
# domain/TLS, which is simply how this deployment happens to be set up.
# Real per-region detail (outagePolygons.json) confirmed to exist but
# also seen empty every time so far - same "wait for a real event"
# situation as TCEC.
EREC_API_URL=REPLACE_ME
