# Duke Energy's live outage API needs a Basic auth token.
DUKE_ENERGY_API_AUTH=Basic REPLACE_ME

# Each of the URLs below is a Florida utility's own live outage-map API
# endpoint. Kept out of the committed code since this repo is public -
# the code itself (parsing, correlation, lifecycle tracking) is the
# real asset here, not any one utility's specific URL.
DUKE_API_BASE=REPLACE_ME
DUKE_API_ORIGIN=REPLACE_ME
TECO_API_URL=REPLACE_ME
TECO_API_ORIGIN=REPLACE_ME
FPL_API_URL=REPLACE_ME
FPL_API_ORIGIN=REPLACE_ME

# JEA's outage map runs on a shared third-party vendor platform - these
# two ids are JEA-specific and worth keeping out of the committed code.
JEA_STORMCENTER_INSTANCE_ID=REPLACE_ME
JEA_STORMCENTER_VIEW_ID=REPLACE_ME

# FPL's second, separate live feed for the Florida Panhandle (Gulf
# Power's former territory - a distinct technical source FPL never
# consolidated into its main feed). Same JSON shape as FPL_API_URL.
FPL_NORTHWEST_API_URL=REPLACE_ME
FPL_NORTHWEST_API_REFERER=REPLACE_ME

# City of Tallahassee's outage map endpoint.
TALLAHASSEE_API_URL=REPLACE_ME

# Talquin Electric Cooperative's outage map endpoint.
TALQUIN_API_URL=REPLACE_ME

# Florida Public Utilities Corporation's outage map endpoint (a POST
# endpoint - the real form fields are hardcoded in
# fetch_fpuc_outages.py itself since none of them are secrets, just
# this base URL is environment-specific enough to keep out of the
# committed code).
FPUC_API_URL=REPLACE_ME

# Peace River Electric Cooperative (PRECO)'s outage map endpoint.
PRECO_API_URL=REPLACE_ME

# Florida Keys Electric Cooperative (FKEC)'s outage map endpoint.
FKEC_API_URL=REPLACE_ME

# Tri-County Electric Cooperative (TCEC)'s outage map endpoint.
TCEC_API_URL=REPLACE_ME

# Escambia River Electric Cooperative (EREC)'s outage map endpoint.
EREC_API_URL=REPLACE_ME

# Choctawhatchee Electric Cooperative (CHELCO)'s outage map endpoint.
CHELCO_API_URL=REPLACE_ME

# Gulf Coast Electric Cooperative (GCEC)'s outage map endpoint.
GCEC_API_URL=REPLACE_ME
