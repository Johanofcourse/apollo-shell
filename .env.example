# Duke Energy's live outage-map API requires a Basic auth token, found
# via browser devtools (not officially documented). Format: "Basic <base64>"
DUKE_ENERGY_API_AUTH=Basic REPLACE_ME

# The endpoints below are each utility's own live outage-map backend,
# found via browser devtools - not officially documented public APIs.
# Kept out of the committed code on purpose (this repo is public) since
# the code itself is more valuable than any one utility's specific
# endpoint - re-finding one is a matter of repeating the same devtools
# process, not copying a secret.
DUKE_API_BASE=REPLACE_ME
DUKE_API_ORIGIN=REPLACE_ME
TECO_API_URL=REPLACE_ME
TECO_API_ORIGIN=REPLACE_ME
FPL_API_URL=REPLACE_ME
FPL_API_ORIGIN=REPLACE_ME
